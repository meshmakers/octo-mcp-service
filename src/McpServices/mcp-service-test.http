Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 12,
  "method": "tools/call",
  "params": {
    "name": "delete_entity",
    "arguments": {
      "ckTypeId": "YourTypeId",
      "rtId": "YourRuntimeId"
    }
  }
}

### List Available Tools
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 13,
  "method": "tools/call",
  "params": {
    "name": "list_available_tools",
    "arguments": {
      "category": null
    }
  }
}

### Get Tool Details
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 14,
  "method": "tools/call",
  "params": {
    "name": "get_tool_details",
    "arguments": {
      "toolName": "get_available_models"
    }
  }
}

### Validate Tool Parameters
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 15,
  "method": "tools/call",
  "params": {
    "name": "validate_tool_parameters",
    "arguments": {
      "toolName": "create_entity",
      "parameters": "{\"ckTypeId\": \"TestType\", \"entityData\": \"{\\\"test\\\": true}\"}"
    }
  }
}

### Get Tool Statistics
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 16,
  "method": "tools/call",
  "params": {
    "name": "get_tool_statistics",
    "arguments": {
      "timeRange": "day"
    }
  }
}