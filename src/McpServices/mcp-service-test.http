}

### Create Entity
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 6,
  "method": "tools/call",
  "params": {
    "name": "create_entity",
    "arguments": {
      "ckTypeId": "EnergyCommunity/Customer",
      "entityData": [
        {
          "attributePath": "Contact.FirstName",
          "value": "Gerald"
        },
        {
          "attributePath": "Contact.LastName",
          "value": "Lochner"
        },
        {
          "attributePath": "Contact.Email",
          "value": "xy@z.com"
        },
        {
          "attributePath": "Contact.Address.Street",
          "value": "test"
        },
        {
          "attributePath": "Contact.Address.Zipcode",
          "value": "5020"
        },
        {
          "attributePath": "Contact.Address.CityTown",
          "value": "test"
        },
        {
          "attributePath": "Contact.Address.NationalCode",
          "value": "AT"
        },
        {
          "attributePath": "TaxProcedureCreditNote",
          "value": 1
        }
      ]
    }
  }
}

### Query Entities Simple
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 7,
  "method": "tools/call",
  "params": {
    "name": "query_entities_simple",
    "arguments": {
      "ckTypeId": "EnergyCommunity/Customer",
      "simpleFilters": [
        {
          "attributePath": "Contact.FirstName",
          "value": "Gerald"
        },
        {
          "attributePath": "Contact.LastName",
          "value": "Lochner"
        }
      ],
      "limit": 10
    }
  }
}

### Query Entities (Advanced)
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 8,
  "method": "tools/call",
  "params": {
    "name": "query_entities",
    "arguments": {
      "ckTypeId": "EnergyCommunity/Customer",
      "filters": {
        "operator": "Or",
        "nestedFilters": [
          {
            "fields": [
              {
                "attributePath": "Contact.FirstName",
                "operator": "Equals",
                "value": "Gerald"
              },
              {
                "attributePath": "Contact.LastName",
                "operator": "Equals",
                "value": "Lochner"
              }
            ],
            "logicalOperator": "And"
          },
          {
            "fields": [
              {
                "attributePath": "Contact.CompanyName",
                "operator": "Equals",
                "value": "meshmakers GmbH"
              }
            ],
            "logicalOperator": "And"
          }
        ]
      },
      "limit": 10,
      "offset": 0
    }
  }
}

### Query Entities
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 8,
  "method": "tools/call",
  "params": {
    "name": "query_entities",
    "arguments": {
      "ckTypeId": "EnergyCommunity/Customer",
      "limit": 100
    }
  }
}

### Get Entity By ID
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 9,
  "method": "tools/call",
  "params": {
    "name": "get_entity_by_id",
    "arguments": {
      "ckTypeId": "EnergyCommunity/Customer",
      "rtId": "6841b558514a7df1ce76b53e"
    }
  }
}

### Update Entity
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 10,
  "method": "tools/call",
  "params": {
    "name": "update_entity",
    "arguments": {
      "ckTypeId": "EnergyCommunity/Customer",
      "rtId": "6841b558514a7df1ce76b53e",
      "entityData": [
        {
          "attributePath": "Contact.FirstName",
          "value": "Gerald Updated"
        }
      ]
    }
  }
}

### Navigate Associations
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 11,
  "method": "tools/call",
  "params": {
    "name": "navigate_associations",
    "arguments": {
      "ckTypeId": "EnergyCommunity/Customer",
      "rtId": "6841b558514a7df1ce76b53e",
      "ckRoleId": "EnergyCommunity/AssociatedCustomer",
      "direction": "Inbound",
      "targetTypeId": "EnergyCommunity/OperatingFacility"
    }
  }
}

### Navigate Associations with filter
POST {{baseUrl}}/{{tenantId}}/mcp
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 11,
  "method": "tools/call",
  "params": {
    "name": "navigate_associations",
    "arguments": {
      "ckTypeId": "EnergyCommunity/Customer",
      "rtId": "6841b558514a7df1ce76b53e",
      "ckRoleId": "EnergyCommunity/AssociatedCustomer",
      "direction": "Inbound",
      "targetTypeId": "EnergyCommunity/OperatingFacility",
      "filters": [
          { "attributePath": "address.street",  "value": "Zeller Fusch 153" }
        ]
    }
  }
}

