{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Meshmakers.Octo.Backend.McpServices": "Debug"
    }
  },
  "AllowedHosts": "*",
  "System": {
    "ServiceName": "McpServices",
    "ServiceVersion": "1.0.0"
  },
  "McpServer": {
    "Name": "OctoMesh MCP Server",
    "Version": "1.0.0",
    "Description": "Model Context Protocol server for OctoMesh Construction Kit operations"
  },
  "DynamicTools": {
    "EnableDynamicToolGeneration": true,
    "CkTypeGraphCacheDurationMinutes": 30,
    "MaxQueryResultLimit": 1000,
    "DefaultQueryLimit": 100,
    "EnableDetailedErrors": false,
    "AnalyticsTimeoutSeconds": 300,
    "EnableToolStatistics": true,
    "PreloadModels": [
      "System-1.0.0",
      "Basic-1.0.0",
      "EnergyCommunity-1.0.0",
      "Industry.Basic-1.0.0",
      "Industry.Energy-1.0.0",
      "Industry.Maintenance-1.0.0"
    ],
    "ExcludedTypes": [
      "System-1.0.0/AutoIncrement-1.0.0",
      "System-1.0.0/Tenant-1.0.0"
    ],
    "DomainTools": {
      "EnableEnergyTools": true,
      "EnableIndustryTools": true,
      "EnableAnalyticsTools": true,
      "EnableEnvironmentTools": false,
      "MaxAnalyticsDateRangeDays": 365,
      "EnableForecasting": true
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "mongodb://localhost:27017",
    "Redis": "localhost:6379"
  },
  "Runtime": {
    "MongoDB": {
      "ConnectionString": "mongodb://localhost:27017",
      "DatabaseNamePrefix": "octo_",
      "EnableChangeStreams": true,
      "MaxConnectionPoolSize": 100
    }
  }
}
