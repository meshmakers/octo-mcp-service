{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Meshmakers.Octo.Backend.McpServices": "Debug",
      "ModelContextProtocol": "Debug"
    }
  },

  "DynamicTools": {
    "EnableDetailedErrors": true,
    "EnableToolStatistics": true,
    "CkTypeGraphCacheDurationMinutes": 5,
    "AnalyticsTimeoutSeconds": 600,
    
    "DomainTools": {
      "EnableEnergyTools": true,
      "EnableIndustryTools": true,
      "EnableAnalyticsTools": true,
      "EnableEnvironmentTools": true,
      "MaxAnalyticsDateRangeDays": 30,
      "EnableForecasting": true
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "mongodb://localhost:27017",
    "Redis": "localhost:6379"
  },

  "Runtime": {
    "MongoDB": {
      "ConnectionString": "mongodb://localhost:27017",
      "DatabaseNamePrefix": "octo_dev_",
      "EnableChangeStreams": true
    }
  }
}
